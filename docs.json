{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Tandemn",
  "description": "Tandemn is an AI infrastructure platform for running inference workloads across heterogeneous GPU clusters. Tandemn schedules jobs, chooses an efficient hardware mix, and gives teams a simple CLI and server workflow for batch inference.",
  "colors": {
    "primary": "#00f4fd",
    "light": "#00f4fd",
    "dark": "#00f4fd"
  },
  "icons": {
    "library": "lucide"
  },
  "favicon": "/favicon.png",
  "navigation": {
    "groups": [
      {
        "group": "Start here",
        "icon": "rocket",
        "pages": [
          "introduction",
          "quickstart"
        ]
      },
      {
        "group": "Getting started",
        "icon": "play",
        "root": "getting-started/index",
        "directory": "card",
        "pages": [
          "getting-started/requirements",
          "getting-started/install-server",
          "getting-started/install-cli",
          "getting-started/run-first-job"
        ]
      },
      {
        "group": "Concepts",
        "icon": "book-open",
        "root": "concepts/index",
        "directory": "card",
        "pages": [
          "concepts/architecture",
          "concepts/batch-inference",
          "concepts/job-lifecycle",
          "concepts/models-and-routing"
        ]
      },
      {
        "group": "Administration",
        "icon": "settings",
        "root": "admin/index",
        "directory": "card",
        "pages": [
          "admin/server-deployment",
          "admin/configuration",
          "admin/environment-variables",
          "admin/troubleshooting"
        ]
      },
      {
        "group": "CLI Reference",
        "icon": "terminal",
        "root": "cli/index",
        "directory": "card",
        "pages": [
          "cli/overview",
          "cli/check",
          "cli/deploy"
        ]
      },
      {
        "group": "Learn more",
        "icon": "circle-help",
        "root": "learn-more/index",
        "directory": "card",
        "pages": [
          "learn-more/faq",
          "learn-more/support",
          "learn-more/links"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.png",
    "dark": "/logo/dark.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:contact@tandemn.com"
      },
      {
        "label": "GitHub",
        "href": "https://github.com/Tandemn-Labs"
      }
    ]
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/Tandemn_labs/",
      "github": "https://github.com/Tandemn-Labs",
      "linkedin": "https://linkedin.com/company/tandemn"
    }
  }
}
